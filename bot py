# Dicionário temporário para guardar os dados dos produtos da loja
PRODUTOS_LOJA = {}

# ==================== MODAL DE CADASTRO ====================
class ModalCadastroProdutos(Modal, title="Cadastrar Produtos da Loja"):
    p1_info = TextInput(
        label="Produto 1 (Nome | Descrição | Valor)",
        style=discord.TextStyle.paragraph,
        placeholder="Ex: VIP 30 Dias | Acesso total | R$ 20,00",
        required=True
    )
    p2_info = TextInput(
        label="Produto 2 (Nome | Descrição | Valor)",
        style=discord.TextStyle.paragraph,
        placeholder="Ex: Cargo Exclusivo | Cor personalizada | R$ 10,00",
        required=True
    )
    p3_info = TextInput(
        label="Produto 3 (Nome | Descrição | Valor)",
        style=discord.TextStyle.paragraph,
        placeholder="Ex: Bot Personalizado | Hospedagem 1M | R$ 50,00",
        required=True
    )

    async def on_submit(self, interaction: discord.Interaction):
        p1 = [x.strip() for x in self.p1_info.value.split('|')]
        p2 = [x.strip() for x in self.p2_info.value.split('|')]
        p3 = [x.strip() for x in self.p3_info.value.split('|')]

        guild_id = interaction.guild.id
        PRODUTOS_LOJA[guild_id] = {
            'prod_1': {'nome': p1[0], 'desc': p1[1] if len(p1) > 1 else '', 'valor': p1[2] if len(p1) > 2 else ''},
            'prod_2': {'nome': p2[0], 'desc': p2[1] if len(p2) > 1 else '', 'valor': p2[2] if len(p2) > 2 else ''},
            'prod_3': {'nome': p3[0], 'desc': p3[1] if len(p3) > 1 else '', 'valor': p3[2] if len(p3) > 2 else ''}
        }

        produtos = PRODUTOS_LOJA[guild_id]

        embed = discord.Embed(
            title="🛒 Loja Oficial",
            description="Selecione um produto no menu abaixo para abrir seu carrinho de atendimento.",
            color=discord.Color.green()
        )
        
        for key, prod in produtos.items():
            embed.add_field(
                name=prod['nome'],
                value=f"**Descrição:** {prod['desc']}\n**Valor:** {prod['valor']}",
                inline=False
            )

        view = View(timeout=None)
        select = Select(
            placeholder="Clique aqui para escolher um produto",
            custom_id="selecionar_produto_loja",
            options=[
                discord.SelectOption(label=produtos['prod_1']['nome'], description=produtos['prod_1']['desc'][:99], value='prod_1'),
                discord.SelectOption(label=produtos['prod_2']['nome'], description=produtos['prod_2']['desc'][:99], value='prod_2'),
                discord.SelectOption(label=produtos['prod_3']['nome'], description=produtos['prod_3']['desc'][:99], value='prod_3'),
            ]
        )

        async def select_callback(interaction: discord.Interaction):
            await handle_select_carrinho(interaction, produtos)

        select.callback = select_callback
        view.add_item(select)

        await interaction.response.send_message("Painel criado com sucesso!", ephemeral=True)
        await interaction.channel.send(embed=embed, view=view)


